{
  "id": "bet-book",
  "name": "Bet Book",
  "version": "1.0.0",
  "description": "A household ledger for long-term predictions, friendly wagers, receipts, reminders, and eventual bragging rights.",
  "entrypoint": "index.html",
  "runtime": "static",
  "category": "family",
  "tags": ["bets", "predictions", "wagers", "household"],
  "data_access": {
    "reads": ["family.members"],
    "writes": []
  },
  "permissions": {
    "default_audience": "everyone",
    "requires_approval": false
  },
  "storage": "db",
  "resource_limits": {
    "max_db_bytes": 52428800
  },
  "row_policies": {
    "participants": { "kind": "endpoint_only", "read": "everyone" },
    "evidence": { "kind": "endpoint_only", "read": "everyone" },
    "amendments": { "kind": "endpoint_only", "read": "everyone" },
    "settlement_votes": { "kind": "endpoint_only", "read": "everyone" },
    "settlement_winners": { "kind": "endpoint_only", "read": "everyone" }
  },
  "append_only_records": {
    "participants": {
      "table": "participants",
      "parent_table": "bets",
      "parent_fk_column": "bet_id",
      "parent_status_column": "status",
      "parent_blocked_status_values": ["settled", "voided"],
      "allowed_columns": ["bet_id", "member_id", "member_name", "side_label", "prediction"],
      "writer_column": "created_by",
      "created_at_column": "created_at",
      "max_text_lengths": {
        "member_id": 120,
        "member_name": 120,
        "side_label": 120,
        "prediction": 1000
      }
    },
    "evidence": {
      "table": "evidence",
      "parent_table": "bets",
      "parent_fk_column": "bet_id",
      "parent_status_column": "status",
      "parent_blocked_status_values": ["settled", "voided"],
      "allowed_columns": ["bet_id", "kind", "label", "url", "notes"],
      "writer_column": "added_by",
      "created_at_column": "added_at",
      "allowed_values": {
        "kind": ["note", "link", "photo", "screenshot"]
      },
      "max_text_lengths": {
        "kind": 20,
        "label": 160,
        "url": 1000,
        "notes": 2000
      }
    },
    "amendments": {
      "table": "amendments",
      "parent_table": "bets",
      "parent_fk_column": "bet_id",
      "parent_status_column": "status",
      "parent_blocked_status_values": ["settled", "voided"],
      "allowed_columns": ["bet_id", "body"],
      "writer_column": "added_by",
      "created_at_column": "added_at",
      "max_text_lengths": {
        "body": 2000
      }
    },
    "settlement_votes": {
      "table": "settlement_votes",
      "parent_table": "bets",
      "parent_fk_column": "bet_id",
      "parent_status_column": "status",
      "parent_blocked_status_values": ["voided"],
      "allowed_columns": ["bet_id", "vote", "notes"],
      "writer_column": "member_id",
      "created_at_column": "created_at",
      "allowed_values": {
        "vote": ["settled", "voided", "agree", "disagree"]
      },
      "max_text_lengths": {
        "vote": 20,
        "notes": 2000
      }
    },
    "settlement_winners": {
      "table": "settlement_winners",
      "parent_table": "bets",
      "parent_fk_column": "bet_id",
      "parent_status_column": "status",
      "parent_blocked_status_values": ["voided"],
      "allowed_columns": ["bet_id", "participant_id"],
      "writer_column": "marked_by",
      "created_at_column": "created_at",
      "max_text_lengths": {
        "participant_id": 120
      }
    }
  },
  "nav": { "label": "Bet Book" },
  "widget": {
    "label": "Open Bets",
    "size": "small"
  },
  "icon": "📖",
  "ai_access": {
    "allowed": true,
    "mode": "read",
    "db_exports": ["open_bets", "scoreboard"]
  }
}
